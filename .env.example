# Copy this file to .env and fill in any values.
# python-dotenv will load it automatically when main.py starts.

# Optional: OddsChecker mobile API key.
# Without this, requests are authenticated purely via TLS-fingerprint spoofing
# (tls_client with Chrome 120 profile).  If OddsChecker ever requires an
# explicit key, obtain it by inspecting the mobile app traffic and set it here.
OC_API_KEY=

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Set to "1" to enable verbose debug output inside oddschecker_client.py
DEBUG_MODE=0
